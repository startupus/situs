# Основные настройки
NODE_ENV=development
PORT=3009

# База данных (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/situs_db

# Безопасность
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
SESSION_SECRET=your-session-secret-minimum-32-characters-long

# Логирование
LOG_LEVEL=info

# CORS (разделенные запятыми)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# Cookies
COOKIE_SECURE=false

# URLs других сервисов
LOGINUS_URL=http://localhost:3001
BILINGUS_URL=http://localhost:3003
GATEWAY_URL=http://localhost:3000

# Настройки доменов
DEFAULT_SITUS_DOMAIN=situs.com
ENABLE_CUSTOM_DOMAINS=true

# Файлы и загрузки
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760